# 공통 환경 변수 — 루트 .env에 정의하면 모든 하위 서비스에서 공유됩니다.
# 서비스별 전용 변수(SLACK_BOT_TOKEN 등)는 각 서비스 디렉토리의 .env에서 관리합니다.

# Anthropic API
ANTHROPIC_API_KEY="sk-ant-..."

# Notion API
NOTION_API_KEY="ntn_..."

# Google Cloud (slack-space-gemini 등 Vertex AI 기반 서비스 사용 시 필요)
GOOGLE_APPLICATION_CREDENTIALS="path/to/your/service-account-key.json"
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
